local Tabs = {}
local CurrentTab = nil

local function CreateTab(Name, Icon)    local TabBtn = New("TextButton", {
        Size = UDim2.new(1, -20, 0, 40),
        Position = UDim2.new(0, 10, 0, (#Tabs * 45) + 20),
        BackgroundColor3 = Color3.fromRGB(25, 25, 30),
        Text = "  " .. Name,
        TextColor3 = Color3.fromRGB(180, 180, 180),
        TextSize = 15,
        Font = Enum.Font.GothamSemibold,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
        ZIndex = 3
    }, Sidebar)
    New("UICorner", {CornerRadius = UDim.new(0, 8)}, TabBtn)
    
    local Page = New("ScrollingFrame", {
        Size = UDim2.new(1, -20, 1, -20),
        Position = UDim2.new(0, 10, 0, 10),
        BackgroundTransparency = 1,
        ScrollBarThickness = 4,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        ZIndex = 3
    }, Content)
    
    local Layout = New("UIListLayout", {
        Padding = UDim.new(0, 10),
        SortOrder = Enum.SortOrder.LayoutOrder
    }, Page)
    
    local Tab = {
        Button = TabBtn,
        Page = Page,
        AddElement = function(self, Type, Name, Config)
            local ElementFrame = New("Frame", {
                Size = UDim2.new(1, 0, 0, 50),
                BackgroundColor3 = Color3.fromRGB(25, 25, 30),
                ZIndex = 4
            }, Page)
            New("UICorner", {CornerRadius = UDim.new(0, 8)}, ElementFrame)
            
            local Label = New("TextLabel", {
                Size = UDim2.new(1, -70, 1, 0),
                Position = UDim2.new(0, 15, 0, 0),
                BackgroundTransparency = 1,
                Text = Name,
                TextColor3 = Color3.fromRGB(255, 255, 255),
                TextSize = 14,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,                ZIndex = 5
            }, ElementFrame)
            
            if Type == "Toggle" then
                local ToggleBox = New("Frame", {
                    Size = UDim2.new(0, 45, 0, 24),
                    Position = UDim2.new(1, -60, 0.5, -12),
                    BackgroundColor3 = Color3.fromRGB(40, 40, 45),
                    ZIndex = 5
                }, ElementFrame)
                New("UICorner", {CornerRadius = UDim.new(1, 0)}, ToggleBox)
                
                local ToggleCircle = New("Frame", {
                    Size = UDim2.new(0, 18, 0, 18),
                    Position = UDim2.new(0, 3, 0.5, -9),
                    BackgroundColor3 = Color3.fromRGB(150, 150, 150),
                    ZIndex = 6
                }, ToggleBox)
                New("UICorner", {CornerRadius = UDim.new(1, 0)}, ToggleCircle)
                
                local Enabled = false
                ElementFrame.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        Enabled = not Enabled
                        PlayClickSound()
                        
                        local pos = Enabled and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
                        local color = Enabled and CurrentTheme or Color3.fromRGB(150, 150, 150)
                        
                        TweenService:Create(ToggleCircle, TweenInfo.new(0.2), {Position = pos, BackgroundColor3 = color}):Play()
                        TweenService:Create(ToggleBox, TweenInfo.new(0.2), {BackgroundColor3 = Enabled and Color3.fromRGB(50, 50, 60) or Color3.fromRGB(40, 40, 45)}):Play()
                        
                        if Config and Config.Callback then Config.Callback(Enabled) end
                    end
                end)
                
            elseif Type == "Dropdown" then
                local DropBtn = New("TextButton", {
                    Size = UDim2.new(0, 80, 0, 30),
                    Position = UDim2.new(1, -95, 0.5, -15),
                    BackgroundColor3 = Color3.fromRGB(40, 40, 45),
                    Text = "Select",
                    TextColor3 = Color3.fromRGB(255, 255, 255),
                    TextSize = 13,
                    Font = Enum.Font.Gotham,
                    ZIndex = 5
                }, ElementFrame)
                New("UICorner", {CornerRadius = UDim.new(0, 6)}, DropBtn)
                
                local DropMenu = New("Frame", {                    Size = UDim2.new(1, -20, 0, 0),
                    Position = UDim2.new(0, 10, 1, 5),
                    BackgroundColor3 = Color3.fromRGB(35, 35, 40),
                    ClipsDescendants = true,
                    Visible = false,
                    ZIndex = 10
                }, ElementFrame)
                New("UICorner", {CornerRadius = UDim.new(0, 6)}, DropMenu)
                
                local MenuLayout = New("UIListLayout", {Padding = UDim.new(0, 5)}, DropMenu)
                
                -- FIX FOR CLIPPING BUG: Dynamically expand main element height when dropdown is open!
                local IsOpen = false
                DropBtn.MouseButton1Click:Connect(function()
                    IsOpen = not IsOpen
                    PlayClickSound()
                    DropMenu.Visible = IsOpen
                    
                    if IsOpen then
                        ElementFrame.Size = UDim2.new(1, 0, 0, 50 + (#Config.Options * 30) + 20)
                        TweenService:Create(DropMenu, TweenInfo.new(0.3), {Size = UDim2.new(1, -20, 0, (#Config.Options * 30) + 20)}):Play()
                    else
                        TweenService:Create(DropMenu, TweenInfo.new(0.3), {Size = UDim2.new(1, -20, 0, 0)}):Play()
                        task.wait(0.3)
                        ElementFrame.Size = UDim2.new(1, 0, 0, 50)
                        DropMenu.Visible = false
                    end
                end)
                
                for _, opt in pairs(Config.Options) do
                    local OptionBtn = New("TextButton", {
                        Size = UDim2.new(1, -10, 0, 25),
                        BackgroundColor3 = Color3.fromRGB(45, 45, 50),
                        Text = opt,
                        TextColor3 = Color3.fromRGB(200, 200, 200),
                        TextSize = 12,
                        Font = Enum.Font.Gotham,
                        ZIndex = 11
                    }, DropMenu)
                    New("UICorner", {CornerRadius = UDim.new(0, 4)}, OptionBtn)
                    
                    OptionBtn.MouseButton1Click:Connect(function()
                        PlayClickSound()
                        DropBtn.Text = opt
                        IsOpen = false
                        TweenService:Create(DropMenu, TweenInfo.new(0.3), {Size = UDim2.new(1, -20, 0, 0)}):Play()
                        task.wait(0.3)
                        ElementFrame.Size = UDim2.new(1, 0, 0, 50)
                        DropMenu.Visible = false
                        if Config.Callback then Config.Callback(opt) end                    end)
                end
            end
            
            return ElementFrame
        end
    }
    
    TabBtn.MouseButton1Click:Connect(function()
        PlayClickSound()
        if CurrentTab then
            CurrentTab.Page.Visible = false
            CurrentTab.Button.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
            CurrentTab.Button.TextColor3 = Color3.fromRGB(180, 180, 180)
        end
        CurrentTab = Tab
        Tab.Page.Visible = true
        Tab.Button.BackgroundColor3 = CurrentTheme
        Tab.Button.TextColor3 = Color3.fromRGB(10, 10, 10)
    end)
    
    table.insert(Tabs, Tab)
    if #Tabs == 1 then
        TabBtn:MouseButton1Click() -- Open first tab by default
    end
    
    return Tab
end

