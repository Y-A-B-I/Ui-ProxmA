-- // ==========================================================
-- // DRAGGABLE SYSTEM (Strictly First-Touch Only to avoid bugs!)
-- // ==========================================================
local dragInput, dragStart, startPos

TopBar.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not dragInput then
        dragInput = input -- Lock onto THIS specific input ID
        dragStart = input.Position
        startPos = MainFrame.Position
        PlayClickSound()
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragInput = nil
            end
        end)
    end
end)

UIS.InputChanged:Connect(function(input)
    -- ONLY update if the moving input is the EXACT same one we started with
    if input == dragInput then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

