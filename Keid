-- // UI CREATION HELPER (Keeps code clean and bug-free)
local function New(Class, Props, Parent)
    local Obj = Instance.new(Class)
    for i, v in pairs(Props or {}) do 
        Obj[i] = v 
    end
    Obj.Parent = Parent
    return Obj
end

